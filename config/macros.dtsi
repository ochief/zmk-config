
/* Macro macro: */
#define str(s) #s
#define MACRO(NAME, BINDINGS, WAITMS, TAPMS) \
    macro_##NAME: macro_##NAME { \
        compatible = "zmk,behavior-macro"; \
        label = str(NAME); \
        #binding-cells = <0>; \
        wait-ms = <WAITMS>; \
        tap-ms = <TAPMS>; \
        bindings = <BINDINGS>; \
    };

