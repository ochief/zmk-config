/*                              30 KEY MATRIX / LAYOUT MAPPING

  ╭─────────────────────┬─────────────────────╮
  │ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
  │ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 │
  │     LB2 LB1 LB0     │     RB0 RB1 RB2     │
  ╰───────────╮ LH1 LH0 │ RH0 RH1 ╭───────────╯
              ╰─────────┴─────────╯             */

// use require-prior-idle-ms for combos
#undef COMBO_HOOK
#define COMBO_HOOK require-prior-idle-ms = <150>;

#define COMBO_TERM_FAST 18
#define COMBO_TERM_SLOW 30

/* ALPHA */
ZMK_COMBO(w,            &kp W,              LT4 LT3,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(m,            &kp M,              LT3 LT2,        DEF,                COMBO_TERM_FAST) 
ZMK_COMBO(b,            &kp B,              LT2 LT1,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(k,            &kp K,              LT1 RT1,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(equal,        &equal,             RT1 RT2,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(comma,        &comma,             RT2 RT3,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(dot,          &dot,               RT3 RT4,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(q,            &kp Q,              LM4 LM3,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(f,            &kp F,              LM3 LM2,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(p,            &kp P,              LM2 LM1,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(j,            &kp J,              LM1 RM1,        DEF,                COMBO_TERM_FAST)
ZMK_COMBO(at,           &kp AT,             RM1 RM2,        DEF NUM SYM,        COMBO_TERM_FAST) //might need unicode
//ZMK_COMBO(screenshot,   &screenshot,        LH1 LH0,        DEF NUM SYM,        COMBO_TERM_FAST)

/* VERTICAL */
ZMK_COMBO(lt,           &kp LT,             LT4 LM4,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(lbkt,         &kp LBKT,           LT3 LM3,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(lbrc,         &kp LBRC,           LT2 LM2,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(lpar,         &kp LPAR,           LT1 LM1,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(rpar,         &kp RPAR,           RT1 RM1,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(rbrc,         &kp RBRC,           RT2 RM2,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(rbkt,         &kp RBKT,           RT3 RM3,        DEF NUM SYM,        COMBO_TERM_FAST)
ZMK_COMBO(gt,           &kp GT,             RT4 RM4,        DEF NUM SYM,        COMBO_TERM_FAST)

/* SYMBOLS */
//ZMK_COMBO(euro,         &euro,              LM4 LM3,        NUM SYM,        COMBO_TERM_FAST)// might need
ZMK_COMBO(dollar,       &kp DOLLAR,         LM3 LM2,            NUM SYM,        COMBO_TERM_FAST)
//ZMK_COMBO(pound,        &pound,             LM2 LM1,        NUM SYM,        COMBO_TERM_FAST)// might need
ZMK_COMBO(pipe,         &kp PIPE,           RM2 RM3,            NUM SYM,        COMBO_TERM_FAST) // might need
ZMK_COMBO(tilde,        &kp TILDE,          RM3 RM4,            NUM SYM,        COMBO_TERM_FAST) // might need unicode

