
/* Macro macro: */
#define str(s) #s
#define MACRO(NAME, BINDINGS, WAITMS, TAPMS) \
    macro_##NAME: macro_##NAME { \
        compatible = "zmk,behavior-macro"; \
        label = str(macro_##NAME); \
        #binding-cells = <0>; \
        wait-ms = <WAITMS>; \
        tap-ms = <TAPMS>; \
        bindings = <BINDINGS>; \
    };

/* macro: */
MACRO(F1, &kp F &macro_release &kp LSHIFT &macro_tap &kp 1, 0, 0)
MACRO(F2, &kp F &macro_release &kp LSHIFT &macro_tap &kp 2, 0, 0)
MACRO(F3, &kp F &macro_release &kp LSHIFT &macro_tap &kp 3, 0, 0)
MACRO(F4, &kp F &macro_release &kp LSHIFT &macro_tap &kp 4, 0, 0)
MACRO(F5, &kp F &macro_release &kp LSHIFT &macro_tap &kp 5, 0, 0)
MACRO(F6, &kp F &macro_release &kp LSHIFT &macro_tap &kp 6, 0, 0)
MACRO(F7, &kp F &macro_release &kp LSHIFT &macro_tap &kp 7, 0, 0)
MACRO(F8, &kp F &macro_release &kp LSHIFT &macro_tap &kp 8, 0, 0)
MACRO(F9, &kp F &macro_release &kp LSHIFT &macro_tap &kp 9, 0, 0)
MACRO(F10, &kp F &macro_release &kp LSHIFT &macro_tap &kp 1 &kp 0, 0, 0)
MACRO(F11, &kp F &macro_release &kp LSHIFT &macro_tap &kp 1 &kp 1, 0, 0)
MACRO(F12, &kp F &macro_release &kp LSHIFT &macro_tap &kp 1 &kp 2, 0, 0)