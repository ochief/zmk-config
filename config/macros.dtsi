
/* Macro macro: */
#define str(s) #s
#define MACRO(&macro_NAME, BINDINGS, WAITMS, TAPMS) \
    macro_##NAME: macro_##NAME { \
        compatible = "zmk,behavior-macro"; \
        label = str(macro_##NAME); \
        #binding-cells = <0>; \
        wait-ms = <WAITMS>; \
        tap-ms = <TAPMS>; \
        bindings = <BINDINGS>; \
    };

