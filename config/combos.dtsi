#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS, MS) \
    combo_##NAME { \
        bindings = <BINDINGS>; \
        key-positions = <KEYPOS>; \
        layers = <LAYERS>; \
        timeout-ms = <MS>; \
    };

combos {
    compatible = "zmk,combos";

    // Chords
    COMBO(ch_the, &ch_the, 2 3, DEF, 50)
};