
/* Macro macro: */
#define str(s) #s
#define MACRO(NAME, BINDINGS, WAITMS, TAPMS) \
    macro_##NAME: macro_##NAME { \
        compatible = "zmk,behavior-macro"; \
        label = str(macro_##NAME); \
        #binding-cells = <0>; \
        wait-ms = <WAITMS>; \
        tap-ms = <TAPMS>; \
        bindings = <BINDINGS>; \
    };

/* macro: */
MACRO(one, &kp O &macro_release &kp LSHIFT &macro_tap &kp N &kp E, 0, 0)
MACRO(two, &kp T &macro_release &kp LSHIFT &macro_tap &kp W &kp O, 0, 0)
MACRO(three, &kp T &macro_release &kp LSHIFT &macro_tap &kp H &kp R &kp E &kp E, 0, 0)
MACRO(four, &kp F &macro_release &kp LSHIFT &macro_tap &kp O &kp U &kp R, 0, 0)
MACRO(five, &kp F &macro_release &kp LSHIFT &macro_tap &kp I &kp V &kp E, 0, 0)
MACRO(six, &kp S &macro_release &kp LSHIFT &macro_tap &kp I &kp X, 0, 0)
MACRO(seven, &kp S &macro_release &kp LSHIFT &macro_tap &kp E &kp V &kp E &kp N, 0, 0)
MACRO(eight, &kp E &macro_release &kp LSHIFT &macro_tap &kp I &kp G &kp H &kp T, 0, 0)
MACRO(nine, &kp N &macro_release &kp LSHIFT &macro_tap &kp I &kp N &kp E, 0, 0)
MACRO(ten, &kp T &macro_release &kp LSHIFT &macro_tap &kp E &kp N, 0, 0)