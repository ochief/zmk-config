
/* Macro macro: */
#define str(s) #s
#define MACRO(NAME, BINDINGS, WAITMS, TAPMS) \
    macro_##NAME: macro_##NAME { \
        compatible = "zmk,behavior-macro"; \
        label = str(macro_##NAME); \
        #binding-cells = <0>; \
        wait-ms = <WAITMS>; \
        tap-ms = <TAPMS>; \
        bindings = <BINDINGS>; \
    };

/* macro: */
MACRO(January, &kp J &macro_release &kp LSHIFT &macro_tap &kp A &kp N &kp U &kp A &kp R &kp Y, 0, 0)
MACRO(February, &kp F &macro_release &kp LSHIFT &macro_tap &kp E &kp B &kp R &kp U &kp A &kp R &kp Y, 0, 0)
MACRO(March, &kp M &macro_release &kp LSHIFT &macro_tap &kp A &kp R &kp C &kp H, 0, 0)
MACRO(April, &kp A &macro_release &kp LSHIFT &macro_tap &kp P &kp R &kp I &kp L, 0, 0)
MACRO(May, &kp M &macro_release &kp LSHIFT &macro_tap &kp A &kp Y, 0, 0)
MACRO(June, &kp J &macro_release &kp LSHIFT &macro_tap &kp U &kp N &kp E, 0, 0)
MACRO(July, &kp J &macro_release &kp LSHIFT &macro_tap &kp U &kp L &kp Y, 0, 0)
MACRO(August, &kp A &macro_release &kp LSHIFT &macro_tap &kp U &kp G &kp U &kp S &kp T, 0, 0)
MACRO(September, &kp S &macro_release &kp LSHIFT &macro_tap &kp E &kp P &kp T &kp E &kp M &kp B &kp E &kp R, 0, 0)
MACRO(October, &kp O &macro_release &kp LSHIFT &macro_tap &kp C &kp T &kp O &kp B &kp E &kp R, 0, 0)
MACRO(November, &kp N &macro_release &kp LSHIFT &macro_tap &kp O &kp V &kp E &kp M &kp B &kp E &kp R, 0, 0)
MACRO(December, &kp D &macro_release &kp LSHIFT &macro_tap &kp E &kp C &kp E &kp M &kp B &kp E &kp R, 0, 0)